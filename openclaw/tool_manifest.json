{
  "name": "localscope",
  "integration_type": "cli_wrapper",
  "native_plugin": false,
  "tools": [
    {
      "name": "local_scope_audit",
      "description": "Run one read-only LocalScope audit through the high-level flow: scan, tasks, run-tasks, report.",
      "command": "python -m adapters.openclaw.local_scope_audit",
      "aliases": ["local_project_audit"],
      "arguments": {
        "path": {
          "type": "string",
          "required": true,
          "description": "Project folder to audit."
        },
        "profile": {
          "type": "string",
          "required": false,
          "default": "auto",
          "enum": ["auto", "general", "php", "wordpress", "javascript", "python", "java", "docker"]
        },
        "mode": {
          "type": "string",
          "required": false,
          "default": "general",
          "enum": ["general", "security", "code_quality"]
        },
        "max_tasks": {
          "type": "integer",
          "required": false,
          "default": 5,
          "minimum": 1
        },
        "use_memory": {
          "type": "boolean",
          "required": false,
          "default": true
        },
        "use_graphify": {
          "type": "boolean",
          "required": false,
          "default": true
        },
        "read_only": {
          "type": "boolean",
          "required": true,
          "default": true,
          "const": true
        }
      },
      "response": {
        "status": "completed|failed",
        "adapter": "openclaw",
        "project_path": "string",
        "profile_detected": "string",
        "report_markdown": "string",
        "report_json": "string",
        "tasks_processed": "integer",
        "reused": "integer",
        "json_valid": "integer",
        "json_repaired": "integer",
        "json_failed": "integer",
        "summary": "string",
        "errors": "array"
      },
      "safety": {
        "read_only": true,
        "exposes_low_level_file_tools": false,
        "exposes_shell_tools": false,
        "allows_editing": false,
        "allows_patch_application": false
      }
    }
  ]
}
